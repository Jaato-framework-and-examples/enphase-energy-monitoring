# =============================================================================
# ENPHASE GATEWAY CONFIGURATION
# =============================================================================
ENPHASE_GATEWAY_IP=
ENPHASE_GATEWAY_SERIAL=
ENPHASE_GATEWAY_PORT=443
ENPHASE_POLL_INTERVAL_SECONDS=300

# =============================================================================
# ENLIGHTEN PORTAL CREDENTIALS
# =============================================================================
# Required for automatic token acquisition
# Get credentials from: https://enlighten.enphaseenergy.com/login
ENLIGHTEN_EMAIL=your-email@example.com
ENLIGHTEN_PASSWORD=your-password

# =============================================================================
# INFLUXDB CONFIGURATION
# =============================================================================
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=enphase-monitoring-token
INFLUXDB_ORG=energy_monitoring
INFLUXDB_BUCKET=home_energy

# =============================================================================
# GRAFANA CONFIGURATION
# =============================================================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_SERVER_ROOT_URL=http://localhost:3000

# =============================================================================
# JAATO ADVISOR CONFIGURATION
# =============================================================================
JAATO_SOCKET_PATH=/tmp/jaato.sock
ADVISOR_INTERVAL_SECONDS=300
ADVISOR_LATITUDE=40.4168
ADVISOR_LONGITUDE=-3.7038

# Optional: External API keys
ESIOS_TOKEN=
OPENWEATHER_API_KEY=

# =============================================================================
# JAATO SDK CONFIGURATION
# =============================================================================
# Provider & Model
JAATO_PROVIDER=zhipuai
MODEL_NAME=glm-4.7

# Logs — all redirected to ./logs
JAATO_TRACE_LOG=./logs/rich_client_trace.log
JAATO_PROVIDER_TRACE=./logs/provider_trace.log
#RICH_BUFFER_TRACE=./logs/rich_render_trace.log
RICH_BUFFER_TRACE=
JAATO_SESSION_LOG_DIR=./logs

# Debug
VERBOSE=1
AI_USE_CHAT_FUNCTIONS=1

# No timeout on interactive prompts (0 = wait forever)
JAATO_PERMISSION_TIMEOUT=0
JAATO_CLARIFICATION_TIMEOUT=0
