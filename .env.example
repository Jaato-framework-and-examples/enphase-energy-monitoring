# =============================================================================
# Enphase Energy Monitoring System - Configuration Example
# =============================================================================
# Copy this file to .env and customize with your settings
# Run: cp .env.example .env

# =============================================================================
# GATEWAY CONFIGURATION
# =============================================================================
# If you know your gateway IP and serial, set them here to skip discovery
# Leave empty to enable automatic mDNS/Bonjour discovery
# 
# To find your gateway details, run: python examples/discover_gateways.py

ENPHASE_GATEWAY_IP=
ENPHASE_GATEWAY_SERIAL=
ENPHASE_GATEWAY_PORT=443

# =============================================================================
# POLLING CONFIGURATION
# =============================================================================
# How often to poll the gateway for energy data (in seconds)
# 
# Recommended values:
#   - 300 (5 minutes) - Default, gateway-friendly
#   - 60 (1 minute) - More frequent data
#   - 10 (10 seconds) - Very frequent (may stress gateway)
# 
# WARNING: Polling too frequently may stress your gateway or cause it to
# become unresponsive. If your gateway disappears from the network,
# increase this value.

ENPHASE_POLL_INTERVAL_SECONDS=300

# =============================================================================
# ENLIGHTEN PORTAL AUTHENTICATION (Optional)
# =============================================================================
# Your Enphase Enlighten portal credentials for automatic token acquisition
# 
# Required for:
#   - Automatic JWT token refresh
#   - Gateway authentication (if token expires)
# 
# Get your credentials from: https://enlighten.enphaseenergy.com
# 
# Note: Tokens are cached locally, so the portal is only contacted when
# the cached token expires (typically after 1 year)

ENLIGHTEN_EMAIL=your-email@example.com
ENLIGHTEN_PASSWORD=your-password

# =============================================================================
# TOKEN CACHE CONFIGURATION
# =============================================================================
# Directory to store cached authentication tokens
# 
# Docker mode:   /app/data/.enphase_tokens (writable by app user)
# Native mode:   ~/.enphase or /tmp/.enphase_tokens
# 
# Tokens are cached per gateway serial number to support multi-gateway setups

ENPHASE_TOKEN_CACHE=/tmp/.enphase_tokens

# =============================================================================
# INFLUXDB CONFIGURATION
# =============================================================================
# InfluxDB connection settings
# 
# Docker mode:
#   - URL: http://localhost:8086 (accessible via network_mode: host)
#   - Token: Set a secure token here (auto-generated if empty)
# 
# Native mode:
#   - URL: http://localhost:8086 (if running InfluxDB locally)
#   - Token: Set your InfluxDB token here

INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=enphase-monitoring-token
INFLUXDB_ORG=energy_monitoring
INFLUXDB_BUCKET=home_energy

# =============================================================================
# GRAFANA CONFIGURATION
# =============================================================================
# Grafana settings for Docker mode
# 
# Default credentials: admin / admin
# You'll be prompted to change these on first login

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_SERVER_ROOT_URL=http://localhost:3000

# =============================================================================
# ADVANCED OPTIONS
# =============================================================================
# These settings are for advanced users and typically don't need to be changed

# InfluxDB retention period (default: 30 days)
INFLUXDB_RETENTION_DAYS=30

# Enable debug logging (default: false)
# Set to 'true' to enable verbose logging for troubleshooting
DEBUG=false

# Log level for Python applications (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
