.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Build artifacts
.build_version

# InfluxDB data (if running locally)
influxdb_data/
grafana_data/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# jaato workspace: ignore runtime state (sessions, logs, stored auth, vision),
# but DO track the profile-set + agent personas (versioned source).
.jaato/*
!.jaato/profiles/
!.jaato/agents/

# Editor / language-server junk
.jdtls/

# Stray env backup — may contain real credentials, never commit
.env.bak
